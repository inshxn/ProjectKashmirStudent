# ─────────────────────────────────────────────────────────────────────────────
# Kashmir Student — Environment Variables
# 1. Copy this file to .env.local for local development
# 2. Add ALL vars in: Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ───────────────────────────────────────────────────────────────────
# Local: http://localhost:3000   |   Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Kashmir Student

# ── Admin Auth ────────────────────────────────────────────────────────────────
# MUST be set in Vercel — without this, admin login returns 500 and the
# dashboard becomes accessible to everyone.
# Generate one at: https://generate-secret.vercel.app/32
ADMIN_SECRET_KEY=change-this-to-a-long-random-secret

# ── Optional Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
